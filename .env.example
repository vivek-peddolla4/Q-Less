# ══════════════════════════════════════════════════════════════════
# Q-LESS  —  Environment Variables Template
# ══════════════════════════════════════════════════════════════════
# 1. Copy this file:   cp .env.example .env
# 2. Fill in every value marked with <REPLACE_...>
# 3. NEVER commit your .env file (it is in .gitignore)
# ══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# BACKEND
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (include your real password)
MONGO_URI=mongodb+srv://<DB_USER>:<DB_PASSWORD>@<CLUSTER>.mongodb.net/qless?retryWrites=true&w=majority

# JWT Secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<REPLACE_WITH_64_CHAR_RANDOM_HEX>

# Redis URL
# - Local dev:  redis://127.0.0.1:6379
# - Docker:     redis://redis:6379
REDIS_URL=redis://redis:6379

# AI Service URL
# - Local dev:  http://127.0.0.1:5000
# - Docker:     http://ai-service:5000
AI_SERVICE_URL=http://ai-service:5000

# Optional: SendGrid email notifications (leave blank to disable)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourdomain.com

# Optional: Twilio SMS notifications (leave blank to disable)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# ─────────────────────────────────────────────────────────────
# FRONTEND (Vite build-time variables)
# These are embedded into the JS bundle at build time.
# ─────────────────────────────────────────────────────────────

# Public URL of your deployed backend API
VITE_API_URL=https://api.yourdomain.com

# Public URL of your deployed AI service
VITE_AI_SERVICE_URL=https://ai.yourdomain.com
